generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Tier {
  S
  A
  B
  C
  D
}

model Hotel {
  id        String   @id @default(cuid())
  name      String
  brand     String
  tier      Tier
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier, position])
  @@index([brand])
}